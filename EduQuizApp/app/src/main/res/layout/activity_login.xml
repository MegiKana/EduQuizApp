<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A">

    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="28dp">

        <TextView
            android:id="@+id/tvLoginTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Welcome to\nEduQuiz App"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginTop="40dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvLoginSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Learn English vocabulary by level, practice with quizzes, and track your progress."
            android:textSize="17sp"
            android:textColor="#DDE6F0"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginTop="18dp"
            app:layout_constraintTop_toBottomOf="@id/tvLoginTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/etLoginName"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:hint="Member name"
            android:textColor="#FFFFFF"
            android:textColorHint="#DDE6F0"
            android:backgroundTint="#00E5FF"
            android:padding="14dp"
            android:layout_marginTop="45dp"
            app:layout_constraintTop_toBottomOf="@id/tvLoginSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/etLoginPassword"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:hint="Password"
            android:inputType="textPassword"
            android:textColor="#FFFFFF"
            android:textColorHint="#DDE6F0"
            android:backgroundTint="#00E5FF"
            android:padding="14dp"
            android:layout_marginTop="18dp"
            app:layout_constraintTop_toBottomOf="@id/etLoginName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvLoginMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/etLoginPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:text="Login"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#00C9E8"
            android:layout_marginTop="22dp"
            app:layout_constraintTop_toBottomOf="@id/tvLoginMessage"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvCreateText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Don’t have a membership?"
            android:textSize="16sp"
            android:textColor="#DDE6F0"
            android:gravity="center"
            android:layout_marginTop="34dp"
            app:layout_constraintTop_toBottomOf="@id/btnLogin"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnGoCreateAccount"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:text="Create Account &amp; Start Learning"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#00C9E8"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/tvCreateText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
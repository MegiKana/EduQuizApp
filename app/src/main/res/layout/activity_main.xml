<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A"
    android:padding="22dp">

    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="EduQuiz App"
        android:textSize="34sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:layout_marginTop="34dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Welcome, Student!"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#DDE6F0"
        android:gravity="center"
        android:layout_marginTop="28dp"
        app:layout_constraintTop_toBottomOf="@id/tvAppTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvLevel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Your learning level: Beginner"
        android:textSize="18sp"
        android:textColor="#AFC7E8"
        android:gravity="center"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/tvWelcome"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvBestScore"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Best score: 0 / 10"
        android:textSize="16sp"
        android:textColor="#AFC7E8"
        android:gravity="center"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvLevel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvMotivation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Learn, practice, and improve your English step by step."
        android:textSize="16sp"
        android:textColor="#DDE6F0"
        android:gravity="center"
        android:layout_marginTop="22dp"
        app:layout_constraintTop_toBottomOf="@id/tvBestScore"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnLessons"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:text="Open Lessons"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="#00C9E8"
        android:layout_marginTop="40dp"
        app:layout_constraintTop_toBottomOf="@id/tvMotivation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnQuiz"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:text="Start Level Quiz"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="#00C9E8"
        android:layout_marginTop="18dp"
        app:layout_constraintTop_toBottomOf="@id/btnLessons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnSettings"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:text="Progress &amp; Settings"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="#00C9E8"
        android:layout_marginTop="18dp"
        app:layout_constraintTop_toBottomOf="@id/btnQuiz"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#102A43"
        android:padding="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:text="🏠"
            android:textAllCaps="false"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#00C9E8" />

        <Button
            android:id="@+id/navLessons"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:text="📚"
            android:textAllCaps="false"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#102A43" />

        <Button
            android:id="@+id/navQuiz"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:text="❓"
            android:textAllCaps="false"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#102A43" />

        <Button
            android:id="@+id/navProgress"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:text="⭐"
            android:textAllCaps="false"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#102A43" />

        <Button
            android:id="@+id/navLogout"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:text="🚪"
            android:textAllCaps="false"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#102A43" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>